# ==========================================
# Rival Task Manager - Environment Variables
# ==========================================

# -----------------
# Backend Config
# -----------------

# PostgreSQL Database Connection String
# Replace user, password, and db_name with your actual credentials
DATABASE_URL="postgresql://postgres:password123@localhost:5432/rival_tasks?schema=public"

# JSON Web Token Secret Key (Change this in production!)
JWT_SECRET="supersecretjwtkey_rival_task_manager"

# Backend API Port
PORT=5000

# -----------------
# Frontend Config
# -----------------

# The URL of your backend API (used by Next.js client)
NEXT_PUBLIC_API_URL="http://localhost:5000/api"
